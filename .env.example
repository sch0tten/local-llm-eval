# vLLM server hostname or IP
VLLM_HOST=localhost

# SSH target for remote server management (user@host)
VLLM_SSH=user@your-server

# Path to model-serve.sh on the remote server
VLLM_MODEL_CMD=/path/to/model-serve.sh

# Remote user for systemd-run (bench-coding.py)
VLLM_USER=your-username

# HuggingFace cache paths on the remote server
VLLM_HF_HOME=/path/to/hf-cache
VLLM_HF_HUB=/path/to/hf-models

# Python venv path for model-serve.sh
VLLM_VENV=/path/to/.venv
